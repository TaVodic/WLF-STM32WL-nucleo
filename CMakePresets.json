{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
		    "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake",
            "cacheVariables": {
            }
        },
        {
            "name": "Debug_TRANSMITTER",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "DEFINE_NODE": "ON",
                "NODE": "1"
            }
            
        },
        {
            "name": "Debug_RECEIVER",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "DEFINE_NODE": "ON",
                "NODE": "2"
            }
        },
        {
            "name": "Devel",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Devel",
                "DEFINE_NODE": "OFF"
            }
        },
        {
            "name": "Release",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug_TRANSMITTER",
            "configurePreset": "Debug_TRANSMITTER"
        },
        {
            "name": "Debug_RECEIVER",
            "configurePreset": "Debug_RECEIVER"
        },
        {
            "name": "Devel",
            "configurePreset": "Devel"
        },
        {
            "name": "Release",
            "configurePreset": "Release"
        }
    ]
}
